# ============================================================================
# DISCORD CONFIGURATION
# ============================================================================
# Bot ID: https://discord.com/developers/applications
DISCORD_BOT_ID=

# Bot token: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# Server ID: Enable Developer Mode → Right-click server → Copy ID
DISCORD_SERVER_ID=

# ============================================================================
# LLM PROVIDER SETTINGS
# ============================================================================
# Summarization function (options: google, groq, deepseek)
SUMMARY_PROVIDER=groq
SUMMARY_MODEL=moonshotai/kimi-k2-instruct

# Google (Gemini) - https://console.cloud.google.com/
GOOGLE_API_KEY=
GOOGLE_GEMINI_MODEL=gemini-2.5-flash

# DeepSeek - https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Groq - https://console.groq.com/keys
GROQ_API_KEY=

# ============================================================================
# EXTERNAL API KEYS
# ============================================================================
# Weather data - https://www.weatherapi.com/signup.aspx
WEATHERAPI_API_KEY=

# Local time - https://api.ipgeolocation.io/timezone
LOCALTIME_API_KEY=

# Currency exchange rates - https://app.currencyapi.com/register
CURRENCYAPI_API_KEY=

# Acqin services - https://acqin.org/api-access
ACQIN_API_KEY=

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Database connection URL (default: SQLite)
DATABASE_URL=sqlite:///cocobot.db
DB_POOL_SIZE=5
DB_ECHO=false
INIT_DB_ON_STARTUP=true

# ============================================================================
# CACHE CONFIGURATION (Optional)
# ============================================================================
# CACHE_ENABLED=true
# REDIS_URL=
# CACHE_TTL=3600

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=WARNING
LOG_FILE=logs/cocobot.log
LOG_MAX_BYTES=1485760
LOG_BACKUP_COUNT=3

# ============================================================================
# SECURITY & PERFORMANCE
# ============================================================================
MAX_CONTENT_LENGTH=10000
ALLOWED_MENTIONS=true
ENABLE_CORS=false

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=production
DEBUG=false

# ============================================================================
# JAIL SYSTEM CONFIGURATION
# ============================================================================
# Discord role ID for "Jailed" role
JAIL_ROLE_ID=<DISCORD_ROLE_ID>

# August Engelhardt internal API (for jail integration)
AUGUST_INTERNAL_PORT=17432
AUGUST_INTERNAL_SECRET=<SHARED_SECRET>
