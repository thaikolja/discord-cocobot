# Discord bot ID (https://discord.com/developers/applications)
DISCORD_BOT_ID=

# Discord bot token (https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=

# Discord server ID (Enable Developer Mode in Discord -> Right-click server -> Copy ID)
DISCORD_SERVER_ID=

# WeatherAPI key for accessing weather data (https://www.weatherapi.com/signup.aspx)
WEATHERAPI_API_KEY=

# LocalTimeAPI key for accessing local time data (https://timezonedb.com/register)
LOCALTIME_API_KEY=

# CurrencyAPI key for accessing currency exchange rates (https://app.currencyapi.com/register)
CURRENCYAPI_API_KEY=

# Groq API key and model (https://console.groq.com/keys)
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# Google Gemini API key for accessing Gemini AI services (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Gemini model name (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# DeepSeek API key (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# AI provider for summarization (options: groq, gemini, deepseek)
SUMMARY_PROVIDER=groq
SUMMARY_MODEL=openai/gpt-oss-120b


# Geoapify API key for accessing Geoapify services (https://www.geoapify.com/get-api-key)
GEOAPFIY_API_KEY=

# Acqin API key for accessing Acqin services (https://acqin.org/api-access)
ACQIN_API_KEY=

# Logging configuration
LOG_LEVEL=WARNING

# Location of the log file
LOG_FILE=logs/cocobot.log

# Number of backup log files to keep
LOG_BACKUP_COUNT=3

# AI Jail configuration — role ID for the "Jailed" Discord role
JAIL_ROLE_ID=<DISCORD_ROLE_ID>

# Host and port for August Engelhardt's internal HTTP API
# Use 127.0.0.1 for local development
# Use host.docker.internal for Docker (requires extra_hosts in docker-compose.yml for Linux)
AUGUST_INTERNAL_HOST=127.0.0.1
AUGUST_INTERNAL_PORT=17432

# A shared secret for authenticating requests to August Engelhardt's internal HTTP API (must match the value in the bot's configuration)
AUGUST_INTERNAL_SECRET=<SHARED_SECRET>
